generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  supabaseUserId String          @unique
  role           Role
  email          String
  phoneNumber    String?
  country        String?
  state          String?
  firstName      String?
  lastName       String?
  created_at     DateTime        @default(now())
  Admin          Admin?
  Client         Client?
  feedbacks      Feedback[]
  meetings       Meeting[]
  notifications  Notification[]
  Partner        Partner?
  payments       Payment[]
  qnaQuestions   QnA[]
  qnaAnswers     QnAAnswer[]
  requirements   Requirement[]
  supportTickets SupportTicket[]
}

model Client {
  uid            String          @id @default(cuid())
  userId         String          @unique
  User           User            @relation(fields: [userId], references: [id])
  feedbacks      Feedback[]
  meetings       Meeting[]
  projects       Project[]
  requirements   Requirement[]
  supportTickets SupportTicket[]
}

model Admin {
  uid      String    @id @default(cuid())
  userId   String    @unique
  User     User      @relation(fields: [userId], references: [id])
  meetings Meeting[]
  projects Project[]
}

model Partner {
  uid                String          @id @default(cuid())
  userId             String          @unique
  companyName        String?
  companyDescription String?
  BRD                String?
  meetingDate        DateTime?
  Agreement          String?
  phoneNumber        String?
  companyEmail       String?
  companyWebsite     String?
  feedbacks          Feedback[]
  meetings           Meeting[]
  User               User            @relation(fields: [userId], references: [id])
  projects           Project[]
  requirements       Requirement[]
  supportTickets     SupportTicket[]
}

model Project {
  id                 String         @id @default(cuid())
  clientId           String?
  adminId            String?
  partnerId          String?
  description        String?
  readMe             String?
  techStack          String?
  clientRequirement  String?
  projectInformation String?
  projectTimeline    Json?
  projectStatus      ProjectStatus?
  projectFeatures    String?
  priority           Priority?
  progressStatus     String?
  miscellaneousData  Json?
  paymentStatus      PaymentStatus?
  updated_at         DateTime       @default(now())
  created_at         DateTime       @default(now())
  Budget             String?
  meetings           Meeting[]
  payments           Payment[]
  Admin              Admin?         @relation(fields: [adminId], references: [uid])
  Client             Client?        @relation(fields: [clientId], references: [uid])
  Partner            Partner?       @relation(fields: [partnerId], references: [uid])
}

model Requirement {
  uid          String            @id @default(cuid())
  projectTitle String?
  description  String?
  updated_at   DateTime          @default(now())
  created_at   DateTime          @default(now())
  Budget       String?
  clientId     String?
  partnerId    String?
  userId       String?
  email        String?
  userName     String?
  status       RequirementStatus @default(Pending)
  Client       Client?           @relation(fields: [clientId], references: [uid])
  Partner      Partner?          @relation(fields: [partnerId], references: [uid])
  User         User?             @relation(fields: [userId], references: [id])
}

model LandingEnquiry {
  uid        String   @id @default(cuid())
  fullName   String
  email      String
  phone      String
  companyOrg String?
  message    String
  haveSource String?
  updated_at DateTime @default(now())
  created_at DateTime @default(now())
}

model CourseEnquiry {
  uid        String   @id @default(cuid())
  courseId   String
  email      String
  created_at DateTime @default(now())
}

model SupportTicket {
  uid               String        @id @default(cuid())
  ticketId          String        @unique
  userId            String?
  clientId          String?
  partnerId         String?
  issueType         String
  description       String
  priority          Priority
  additionalDetails String?
  status            TicketStatus  @default(pending)
  userName          String?
  email             String?
  updated_at        DateTime      @default(now())
  created_at        DateTime      @default(now())
  Client            Client?       @relation(fields: [clientId], references: [uid])
  Partner           Partner?      @relation(fields: [partnerId], references: [uid])
  User              User?         @relation(fields: [userId], references: [id])
  replies           TicketReply[]
}

model Feedback {
  uid             String   @id @default(cuid())
  userId          String?
  clientId        String?
  partnerId       String?
  overallRating   Int
  serviceQuality  Int?
  communication   Int?
  timeliness      Int?
  valueForMoney   Int?
  feedback        String?
  wouldRecommend  Boolean?
  improvements    String?
  favoriteFeature String?
  userName        String?
  email           String?
  updated_at      DateTime @default(now())
  created_at      DateTime @default(now())
  isTopFeedback   Boolean  @default(false)
  Client          Client?  @relation(fields: [clientId], references: [uid])
  Partner         Partner? @relation(fields: [partnerId], references: [uid])
  User            User?    @relation(fields: [userId], references: [id])
}

model Notification {
  id         String           @id @default(cuid())
  title      String
  message    String
  type       NotificationType @default(info)
  userId     String?
  isRead     Boolean          @default(false)
  created_at DateTime         @default(now())
  updated_at DateTime         @default(now())
  User       User?            @relation(fields: [userId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  userId        String?
  clientId      String?
  projectId     String?
  amount        Float
  currency      String        @default("USD")
  status        PaymentStatus @default(pending)
  paymentMethod String?
  transactionId String?       @unique
  description   String?
  metadata      Json?
  created_at    DateTime      @default(now())
  updated_at    DateTime      @default(now())
  Project       Project?      @relation(fields: [projectId], references: [id])
  User          User?         @relation(fields: [userId], references: [id])
}

model Community {
  id         String   @id @default(cuid())
  title      String
  content    String
  authorId   String?
  category   String?
  tags       String[]
  likes      Int      @default(0)
  views      Int      @default(0)
  isPinned   Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
}

model QnA {
  id         String      @id @default(cuid())
  question   String
  answer     String?
  userId     String?
  category   String?
  tags       String[]
  isAnswered Boolean     @default(false)
  views      Int         @default(0)
  created_at DateTime    @default(now())
  updated_at DateTime    @default(now())
  User       User?       @relation(fields: [userId], references: [id])
  answers    QnAAnswer[]
}

model QnAAnswer {
  id         String   @id @default(cuid())
  qnaId      String
  answer     String
  userId     String?
  isAccepted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  QnA        QnA      @relation(fields: [qnaId], references: [id], onDelete: Cascade)
  User       User?    @relation(fields: [userId], references: [id])
}

model TicketReply {
  id            String        @id @default(cuid())
  ticketId      String
  reply         String
  userId        String?
  isAdmin       Boolean       @default(false)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @default(now())
  SupportTicket SupportTicket @relation(fields: [ticketId], references: [uid], onDelete: Cascade)
}

model Meeting {
  id               String               @id @default(cuid())
  title            String
  description      String?
  date             DateTime
  startTime        String
  endTime          String
  type             MeetingType
  location         String?
  meetingLink      String?
  status           MeetingStatus        @default(upcoming)
  userId           String
  clientId         String?
  partnerId        String?
  adminId          String?
  projectId        String?
  googleEventId    String?              @unique
  syncedWithGoogle Boolean              @default(false)
  created_at       DateTime             @default(now())
  updated_at       DateTime             @default(now())
  Admin            Admin?               @relation(fields: [adminId], references: [uid])
  Client           Client?              @relation(fields: [clientId], references: [uid])
  Partner          Partner?             @relation(fields: [partnerId], references: [uid])
  Project          Project?             @relation(fields: [projectId], references: [id])
  User             User                 @relation(fields: [userId], references: [id])
  participants     MeetingParticipant[]
}

model MeetingParticipant {
  id         String   @id @default(cuid())
  meetingId  String
  email      String
  name       String?
  role       String?
  created_at DateTime @default(now())
  Meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

enum Role {
  client
  admin
  partner
}

enum Priority {
  low
  mid
  high
}

enum ProjectStatus {
  not_started
  initiated
  in_progress
  completed
  delivered
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum TicketStatus {
  pending
  in_progress
  resolved
  closed
}

enum RequirementStatus {
  Contacted
  Pending
  Rejected
}

enum NotificationType {
  info
  success
  warning
  error
  reminder
  update
}

enum MeetingType {
  video
  in_person
  phone
}

enum MeetingStatus {
  upcoming
  completed
  cancelled
}
