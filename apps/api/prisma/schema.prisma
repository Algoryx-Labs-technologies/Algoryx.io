generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  uid     String    @id
  userId  String    @unique
  User    User      @relation(fields: [userId], references: [id])
  Meeting Meeting[]
  Project Project[]
}

model Client {
  uid           String          @id
  userId        String          @unique
  User          User            @relation(fields: [userId], references: [id])
  Feedback      Feedback[]
  Meeting       Meeting[]
  Project       Project[]
  Requirement   Requirement[]
  SupportTicket SupportTicket[]
}

model Community {
  id         String   @id
  title      String
  content    String
  authorId   String?
  category   String?
  tags       String[]
  likes      Int      @default(0)
  views      Int      @default(0)
  isPinned   Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
}

model CourseEnquiry {
  uid        String   @id
  courseId   String
  email      String
  created_at DateTime @default(now())
}

model Feedback {
  uid             String   @id
  userId          String?
  clientId        String?
  partnerId       String?
  overallRating   Int
  serviceQuality  Int?
  communication   Int?
  timeliness      Int?
  valueForMoney   Int?
  feedback        String?
  wouldRecommend  Boolean?
  improvements    String?
  favoriteFeature String?
  userName        String?
  email           String?
  updated_at      DateTime @default(now())
  created_at      DateTime @default(now())
  isTopFeedback   Boolean  @default(false)
  Client          Client?  @relation(fields: [clientId], references: [uid])
  Partner         Partner? @relation(fields: [partnerId], references: [uid])
  User            User?    @relation(fields: [userId], references: [id])
}

model LandingEnquiry {
  uid        String   @id
  fullName   String
  email      String
  phone      String
  companyOrg String?
  message    String
  haveSource String?
  updated_at DateTime @default(now())
  created_at DateTime @default(now())
}

model Meeting {
  id               String        @id
  title            String
  description      String?
  date             DateTime
  startTime        String
  endTime          String
  type             MeetingType
  location         String?
  meetingLink      String?
  status           MeetingStatus @default(upcoming)
  userId           String
  clientId         String?
  partnerId        String?
  adminId          String?
  projectId        String?
  googleEventId    String?       @unique
  syncedWithGoogle Boolean       @default(false)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @default(now())
  Admin            Admin?        @relation(fields: [adminId], references: [uid])
  Client           Client?       @relation(fields: [clientId], references: [uid])
  Partner          Partner?      @relation(fields: [partnerId], references: [uid])
  Project          Project?      @relation(fields: [projectId], references: [id])
  User             User          @relation(fields: [userId], references: [id])
}

model Notification {
  id         String           @id
  title      String
  message    String
  type       NotificationType @default(info)
  userId     String?
  isRead     Boolean          @default(false)
  created_at DateTime         @default(now())
  updated_at DateTime         @default(now())
  User       User?            @relation(fields: [userId], references: [id])
}

model Partner {
  uid                String          @id
  userId             String          @unique
  companyName        String?
  companyDescription String?
  BRD                String?
  meetingDate        DateTime?
  Agreement          String?
  phoneNumber        String?
  companyEmail       String?
  companyWebsite     String?
  Feedback           Feedback[]
  Meeting            Meeting[]
  User               User            @relation(fields: [userId], references: [id])
  Project            Project[]
  Requirement        Requirement[]
  SupportTicket      SupportTicket[]
}

model Payment {
  id            String        @id
  userId        String?
  clientId      String?
  projectId     String?
  amount        Float
  currency      String        @default("USD")
  status        PaymentStatus @default(pending)
  paymentMethod String?
  transactionId String?       @unique
  description   String?
  metadata      Json?
  created_at    DateTime      @default(now())
  updated_at    DateTime      @default(now())
  Project       Project?      @relation(fields: [projectId], references: [id])
  User          User?         @relation(fields: [userId], references: [id])
}

model Project {
  id                 String         @id
  clientId           String?
  adminId            String?
  partnerId          String?
  projectName        String?
  readMe             String?
  techStack          String?
  clientRequirement  String?
  projectInformation String?
  projectTimeline    Json?
  projectStatus      ProjectStatus?
  projectFeatures    String?
  priority           Priority?
  progressStatus     String?
  miscellaneousData  Json?
  paymentStatus      PaymentStatus?
  updated_at         DateTime       @default(now())
  created_at         DateTime       @default(now())
  Budget             String?
  Meeting            Meeting[]
  Payment            Payment[]
  Admin              Admin?         @relation(fields: [adminId], references: [uid])
  Client             Client?        @relation(fields: [clientId], references: [uid])
  Partner            Partner?       @relation(fields: [partnerId], references: [uid])
}

model QnA {
  id         String      @id
  question   String
  answer     String?
  userId     String?
  category   String?
  tags       String[]
  isAnswered Boolean     @default(false)
  views      Int         @default(0)
  created_at DateTime    @default(now())
  updated_at DateTime    @default(now())
  User       User?       @relation(fields: [userId], references: [id])
  QnAAnswer  QnAAnswer[]
}

model QnAAnswer {
  id         String   @id
  qnaId      String
  answer     String
  userId     String?
  isAccepted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  QnA        QnA      @relation(fields: [qnaId], references: [id], onDelete: Cascade)
  User       User?    @relation(fields: [userId], references: [id])
}

model Requirement {
  uid          String            @id
  projectTitle String?
  description  String?
  updated_at   DateTime          @default(now())
  created_at   DateTime          @default(now())
  Budget       String?
  clientId     String?
  partnerId    String?
  userId       String?
  email        String?
  userName     String?
  status       RequirementStatus @default(Pending)
  Client       Client?           @relation(fields: [clientId], references: [uid])
  Partner      Partner?          @relation(fields: [partnerId], references: [uid])
  User         User?             @relation(fields: [userId], references: [id])
}

model SupportTicket {
  uid               String        @id
  ticketId          String        @unique
  userId            String?
  clientId          String?
  partnerId         String?
  issueType         String
  description       String
  priority          Priority
  additionalDetails String?
  status            TicketStatus  @default(pending)
  userName          String?
  email             String?
  updated_at        DateTime      @default(now())
  created_at        DateTime      @default(now())
  Client            Client?       @relation(fields: [clientId], references: [uid])
  Partner           Partner?      @relation(fields: [partnerId], references: [uid])
  User              User?         @relation(fields: [userId], references: [id])
  TicketReply       TicketReply[]
}

model TicketReply {
  id            String        @id
  ticketId      String
  reply         String
  userId        String?
  isAdmin       Boolean       @default(false)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @default(now())
  SupportTicket SupportTicket @relation(fields: [ticketId], references: [uid], onDelete: Cascade)
}

model User {
  id             String          @id
  supabaseUserId String          @unique
  role           Role
  email          String
  phoneNumber    String?
  country        String?
  state          String?
  firstName      String?
  lastName       String?
  created_at     DateTime        @default(now())
  Admin          Admin?
  Client         Client?
  Feedback       Feedback[]
  Meeting        Meeting[]
  Notification   Notification[]
  Partner        Partner?
  Payment        Payment[]
  QnA            QnA[]
  QnAAnswer      QnAAnswer[]
  Requirement    Requirement[]
  SupportTicket  SupportTicket[]
}

enum MeetingStatus {
  upcoming
  completed
  cancelled
}

enum MeetingType {
  video
  in_person
  phone
}

enum NotificationType {
  info
  success
  warning
  error
  reminder
  update
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum Priority {
  low
  mid
  high
}

enum ProjectStatus {
  not_started
  initiated
  in_progress
  completed
  delivered
}

enum RequirementStatus {
  Contacted
  Pending
  Rejected
}

enum Role {
  client
  admin
  partner
}

enum TicketStatus {
  pending
  in_progress
  resolved
  closed
}
