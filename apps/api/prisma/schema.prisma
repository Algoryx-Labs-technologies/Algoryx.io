datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


// ENUMS

enum Role {
  client
  admin
  partner
}

enum Priority {
  low
  mid
  high
}

enum ProjectStatus {
  not_started
  initiated
  in_progress
  completed
  delivered
}

// USER (Base Model)

model User {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique // Link to Supabase Auth user
  role           Role
  email          String
  phoneNumber    String?
  country        String?
  state          String?
  firstName      String?
  lastName       String?
  created_at     DateTime @default(now())

  // Relations
  Client   Client?
  Admin    Admin?
  Partner  Partner?
}


// CLIENT

model Client {
  uid          String   @id @default(cuid())
  userId       String   @unique
  User         User     @relation(fields: [userId], references: [id])

  // Relations (from notes)
  projects     Project[]
  // Requirements are accessed through projects
  // TODO: Uncomment when these models are created
  // notifications Notification[]
  // messages      Message[]
  // calendars     Calendar[]
  // events        Event[]
  // supportTickets SupportTicket[]
  // paymentHistory Payment[]
  // clientNotes    ClientNote[]
}


// ADMIN

model Admin {
  uid     String   @id @default(cuid())
  userId  String   @unique
  User    User     @relation(fields: [userId], references: [id])

  // Relations
  projects Project[]
}


// PARTNER

model Partner {
  uid             String   @id @default(cuid())
  userId          String   @unique
  User            User     @relation(fields: [userId], references: [id])

  companyName        String?
  companyDescription String?
  BRD                String?   // (optional)
  meetingDate        DateTime? // (optional)
  Agreement          String?
  phoneNumber        String?
  companyEmail       String?
  companyWebsite     String?

  // Relations
  projects     Project[]
  // Requirements are accessed through projects
}


enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

// PROJECT

model Project {
  id               String      @id @default(cuid())
  clientId         String?
  Client           Client?     @relation(fields: [clientId], references: [uid])
  adminId          String?
  Admin            Admin?      @relation(fields: [adminId], references: [uid])
  partnerId        String?
  Partner          Partner?    @relation(fields: [partnerId], references: [uid])

  description      String?
  readMe           String?
  techStack        String?
  clientRequirement String?
  projectInformation  String?
  projectTimeline  Json?
  projectStatus    ProjectStatus?
  projectFeatures  String?
  priority         Priority?
  progressStatus   String?
  miscellaneousData   Json?
  Quotation       String?
  paymentStatus    PaymentStatus?

  updated_at       DateTime    @default(now())
  created_at       DateTime    @default(now())

  // Relations
  requirements     Requirement[]
}


// REQUIREMENT

model Requirement {
  uid         String     @id @default(cuid())
  projectId   String?
  Project     Project?   @relation(fields: [projectId], references: [id])

  projectTitle String?
  question     String?
  description  String?
  priority     String?
  answer       String?

  updated_at   DateTime  @default(now())
  created_at   DateTime  @default(now())
}


// LANDING ENQUIRY (Independent Schema)

model LandingEnquiry {
  uid         String   @id @default(cuid())
  fullName    String
  email       String
  phone       String
  address     String
  companyOrg  String?  // (optional)
  message     String
  idProof     String?  // (optional)
  haveSource  String?  // (optional)

  updated_at  DateTime @default(now())
  created_at  DateTime @default(now())
}


// COURSE ENQUIRY (Independent Schema)

model CourseEnquiry {
  uid        String   @id @default(cuid())
  courseId   String
  email      String

  created_at DateTime @default(now())
}
