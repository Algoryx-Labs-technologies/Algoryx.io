NODE_ENV=development
PORT=4001
API_VERSION=v2

MONGODB_URI=mongodb://127.0.0.1:27017/Algoryx
# If mongodb+srv fails with querySrv ECONNREFUSED/ETIMEOUT on Windows, set public DNS:
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

CORS_ORIGIN=http://localhost:8080,http://localhost:5173,http://localhost:5174,http://localhost:5175

# Admin login (apps/adminv2) — store credentials server-side only
ADMIN_ID=admin
ADMIN_PASSWORD=change-me
ADMIN_MPIN=1234
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Landing AI chat (OpenAI — server-side only)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini