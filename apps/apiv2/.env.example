NODE_ENV=development
PORT=4001
API_VERSION=v2

MONGODB_URI=mongodb://127.0.0.1:27017/Algoryx
# If mongodb+srv fails with querySrv ECONNREFUSED/ETIMEOUT on Windows, set public DNS:
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

CORS_ORIGIN=http://localhost:8080,http://localhost:5173,http://localhost:5174

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Landing AI chat (Google AI Studio — server-side only)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash-lite