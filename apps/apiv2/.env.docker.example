# Copy to apps/apiv2/.env before: docker compose up -d --build
# Required for production (see src/config/env.ts)

NODE_ENV=production
PORT=4001
API_VERSION=v2

# With profile `with-db`: docker compose --profile with-db up -d --build
MONGODB_URI=mongodb://mongodb:27017/Algoryx
# Or Atlas / external Mongo (omit `with-db` profile):
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/Algoryx

# Required in production — landing site and any other browser clients
CORS_ORIGIN=https://algoryx.io,https://www.algoryx.io

ADMIN_ID=admin
ADMIN_PASSWORD=change-me-use-a-strong-password
ADMIN_MPIN=1234
JWT_SECRET=change-this-to-a-long-random-secret-min-16-chars
JWT_EXPIRES_IN=8h

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Host port mapping (docker-compose.yml)
API_PUBLISH_PORT=4001
